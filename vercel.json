{
  "version": 2,
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/trpc/(.*)",
      "destination": "server/_core/index.ts"
    },
    {
      "source": "/api/(.*)",
      "destination": "server/_core/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "server/_core/index.ts"
    }
  ]
}
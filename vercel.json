{
  "version": 2,
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm run vercel-build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/trpc/(.*)",
      "destination": "dist/index.js"
    },
    {
      "source": "/api/(.*)",
      "destination": "dist/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "dist/index.js"
    }
  ]
}

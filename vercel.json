{
  "version": 2,
  "buildCommand": "pnpm build",
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "dist/index.js"
    },
    {
      "src": "/trpc/(.*)",
      "dest": "dist/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "dist/$1",
      "check": true
    },
    {
      "src": "/(.*)",
      "status": 200,
      "dest": "dist/index.html"
    }
  ]
}